{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TaskMon",
  "version": "0.1.0",
  "identifier": "com.jongc.taskmon",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "JongCheol Pak",
    "copyright": "Copyright © 2026 JongCheol Pak",
    "category": "Utility",
    "shortDescription": "화면 하단을 달리는 픽셀 아트 데스크톱 펫 + 시스템 모니터링/알림",
    "longDescription": "TaskMon은 작업표시줄 위를 자유롭게 이동하는 픽셀 아트 펫과 함께 CPU·메모리·네트워크·배터리를 실시간으로 모니터링하고, 사용자 정의 알림과 집중 타이머를 표시하는 Windows 데스크톱 펫 애플리케이션입니다.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis-hooks.nsi",
        "languages": ["English", "Korean", "Japanese", "SimpChinese", "TradChinese"],
        "startMenuFolder": ""
      }
    }
  }
}